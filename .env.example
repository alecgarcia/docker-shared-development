# Shared Development – copy to .env and adjust as needed.
# Used by docker-compose when starting services.

# Which services to run (Compose profiles). Comma-separated, no spaces.
# All services are opt-in. Typical dev stack:
#   mysql, pgsql, redis, otel-collector, ngrok
# Also available: nginx-proxy, meilisearch, mailpit, selenium, rustfs, confluent, reverb
COMPOSE_PROFILES=mysql,pgsql,redis,otel-collector,ngrok

# MySQL 8
MYSQL_DB_USERNAME=root
MYSQL_DB_PASSWORD=password
MYSQL_DB_DATABASE=shared-database
FORWARD_DB_PORT=3306

# PostgreSQL 17 (pgvector)
PSQL_DB_USERNAME=root
PSQL_DB_PASSWORD=secret
PSQL_DB_DATABASE=shared-database
PSQL_DB_PORT=5432

# Redis
FORWARD_REDIS_PORT=6379
# REDIS_PASSWORD=   # Uncomment in redis/compose.yml to require auth

# Meilisearch (when enabled)
FORWARD_MEILISEARCH_PORT=7700
MEILISEARCH_NO_ANALYTICS=false

# Mailpit (when enabled)
FORWARD_MAILPIT_PORT=1025
FORWARD_MAILPIT_DASHBOARD_PORT=8025
# UI/API auth: "username:password" or space-separated "user1:pass1 user2:pass2"
# MP_UI_AUTH=admin:secret

# ngrok (when enabled)
# Get token: https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=

# OpenTelemetry Collector (when forwarding to Datadog; uncomment in otel-collector-config.yaml)
# DATADOG_API_KEY=

# RustFS (when enabled) – S3-compatible object storage (MinIO alternative)
# https://docs.rustfs.com/installation/docker
RUSTFS_ACCESS_KEY=rustfsadmin
RUSTFS_SECRET_KEY=rustfsadmin
FORWARD_RUSTFS_API_PORT=9000
FORWARD_RUSTFS_CONSOLE_PORT=9001

# Laravel Reverb host (when profile reverb is enabled)
# Generate APP_KEY: cd reverb-host && php artisan key:generate --show
REVERB_HOST_APP_KEY=
FORWARD_REVERB_PORT=8080
# Horizontal scaling (optional; enable profile redis and set true for multiple Reverb workers)
REVERB_SCALING_ENABLED=false
REVERB_REDIS_HOST=shared-redis
REVERB_REDIS_PORT=6379
# REVERB_REDIS_PASSWORD=
# REVERB_REDIS_URL=
